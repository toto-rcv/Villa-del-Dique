{
  "kind": "collectionType",
  "collectionName": "sponsors",
  "info": {
    "singularName": "sponsor",
    "pluralName": "sponsors",
    "displayName": "Sponsor",
    "description": "Sponsors y auspiciantes del club"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true,
      "maxLength": 160
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "web": {
      "type": "string",
      "maxLength": 300
    },
    "categoria": {
      "type": "enumeration",
      "enum": ["principal", "secundario", "apoyo"],
      "default": "apoyo",
      "required": true
    },
    "orden": {
      "type": "integer",
      "default": 0
    },
    "activo": {
      "type": "boolean",
      "default": true
    },
    "descripcion": {
      "type": "text"
    }
  }
}
